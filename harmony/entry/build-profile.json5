{
  "apiType": "stageMode",
  "buildOption": {
    "externalNativeOptions": {
      "path": "./src/main/cpp/CMakeLists.txt",
      "arguments": ""
    },
    "nativeLib": {
      "filter": {
        "pickFirsts": [
          "**/libhermestooling.so",
          "**/libjsi.so",
          "**/libreactnative.so",
          "**/librnoh_core.so",
          "**/librnoh_core_package.so"
        ]
      }
    }
  },
  "targets": [
    {
      "name": "default",
      "runtimeOS": "HarmonyOS"
    },
    {
      "name": "ohosTest"
    }
  ]
}
