{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": [
    "node_modules",
    ".expo-harmony",
    "harmony",
    "harmony/**/oh_modules",
    "harmony/**/build",
    "harmony/expo-harmony-local-deps"
  ]
}
